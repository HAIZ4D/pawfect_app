# --- Google Gemini AI ---
# Get your key at: https://makersuite.google.com/app/apikey
# Jangan lupa create your own .env file sendiri hihihi
# Then, masukkan kamu punya API Key Sendiri dalam .env hihihi
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# --- Firebase ---
