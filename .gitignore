# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Environment variables - never commit real secrets
.env
.env.local
.env.production
.env.staging

# Firebase - generated files with API keys
firebase_options.dart
google-services.json
google-services*.json
GoogleService-Info.plist
# Firebase deploy cache (build artifact)
.firebase/

# Claude Code - settings and instructions (local only)
.claude/
CLAUDE.md

# All markdown documentation files (local only, not pushed to GitHub)
*.md
# Exception: allow README.md to be pushed
!README.md

# Windows artifacts
nul

# PDF files (may contain sensitive info)
*.pdf
